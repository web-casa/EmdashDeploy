status_command() {
	local as_json="${1:-0}"
	local app_running="false" app_health="failed" setup_status="unreachable" caddy_state="unavailable"
	local sqlite_exists="false"
	local caddy_enabled="false"
	bool_active "${APP_SYSTEMD_SERVICE}" && app_running="true"
	if curl -fsS --max-time 5 "$(local_health_url)" >/dev/null 2>&1; then
		app_health="ok"
	fi
	setup_status="$(
		curl -fsS --max-time 5 "$(local_setup_url)" 2>/dev/null | python3 -c '
import json, sys
try:
    data = json.load(sys.stdin)
    payload = data.get("data", {})
    if payload.get("needsSetup") is False:
        print("complete")
    else:
        print("needs setup (%s)" % payload.get("step", "unknown"))
except Exception:
    print("unreachable")
' || true
	)"
	if [[ "${USE_CADDY}" == "1" ]] && bool_active caddy; then
		caddy_state="active"
	elif [[ "${USE_CADDY}" == "1" ]]; then
		caddy_state="inactive"
	fi
	[[ -f "${SQLITE_PATH}" ]] && sqlite_exists="true"
	[[ "${USE_CADDY}" == "1" ]] && caddy_enabled="true"

	if [[ "${as_json}" == "1" ]]; then
		APP_RUNNING="${app_running}" \
		APP_HEALTH="${app_health}" \
		SETUP_STATUS="${setup_status}" \
		SQLITE_EXISTS="${sqlite_exists}" \
		CADDY_ENABLED="${caddy_enabled}" \
		CADDY_STATE="${caddy_state}" \
		python3 <<PY
import json
import os

def as_bool(name):
    return os.environ[name] == "true"

print(json.dumps({
  "runtime": "native",
  "app_env_file": "${ENV_FILE}",
  "app_url": "${APP_PUBLIC_URL}",
  "app": {
    "running": as_bool("APP_RUNNING"),
    "health": os.environ["APP_HEALTH"],
    "setup_status": os.environ["SETUP_STATUS"],
  },
  "database": {
    "driver": "${DB_DRIVER}",
    "sqlite_path": "${SQLITE_PATH}",
    "sqlite_exists": as_bool("SQLITE_EXISTS")
  },
  "session": {"driver": "${SESSION_DRIVER}", "sessions_dir": "${SESSIONS_DIR}"},
  "caddy": {"enabled": as_bool("CADDY_ENABLED"), "state": os.environ["CADDY_STATE"]}
}, ensure_ascii=False, indent=2))
PY
		return
	fi

	printf '%s: native\n' "$(ct runtime_label)"
	printf '%s: %s\n' "$(ct url_label)" "${APP_PUBLIC_URL}"
	printf '%s: %s\n' "$(ct app_running_label)" "${app_running}"
	printf '%s: %s\n' "$(ct app_health_label)" "${app_health}"
	printf '%s: %s\n' "$(ct setup_status_label)" "${setup_status}"
	printf '%s: %s\n' "$(ct caddy_label)" "${caddy_state}"
