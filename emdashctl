	backup_complete) case "${lang}" in en) printf 'Backup complete' ;; ja) printf 'バックアップ完了' ;; ko) printf '백업 완료' ;; es) printf 'Copia completada' ;; de) printf 'Backup abgeschlossen' ;; fr) printf 'Sauvegarde terminée' ;; zh-CN) printf '备份完成' ;; zh-TW) printf '備份完成' ;; pt) printf 'Backup concluído' ;; esac ;;
