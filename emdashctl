	runtime_label) case "${lang}" in en) printf 'Runtime' ;; ja) printf '运行方式' ;; ko) printf '런타임' ;; es) printf 'Modo' ;; de) printf 'Laufzeit' ;; fr) printf 'Runtime' ;; zh-CN) printf '运行方式' ;; zh-TW) printf '執行方式' ;; pt) printf 'Runtime' ;; esac ;;
