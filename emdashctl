	local app_health_status="fail"
	local setup_api_status="fail"
	local healthy="false"
	local app_service_status="fail"

	curl -fsS --max-time 5 "$(local_health_url)" >/dev/null 2>&1 && app_health_status="ok"
	curl -fsS --max-time 5 "$(local_setup_url)" >/dev/null 2>&1 && setup_api_status="ok"
	bool_active "${APP_SYSTEMD_SERVICE}" && app_service_status="ok"
	if [[ "${app_health_status}" == "ok" ]]; then
		healthy="true"
	fi

	if [[ "${as_json}" == "1" ]]; then
		HEALTHY="${healthy}" python3 <<PY
import json, os

def as_bool(name):
    return os.environ[name] == "true"

checks = [
  {"name": "env file", "status": "ok" if os.path.exists("${ENV_FILE}") else "fail", "detail": "${ENV_FILE}"},
  {"name": "site dir", "status": "ok" if os.path.isdir("${SITE_DIR}") else "fail", "detail": "${SITE_DIR}"},
  {"name": "node", "status": "ok" if os.path.exists("/usr/bin/node") else "fail", "detail": "/usr/bin/node"},
  {"name": "pnpm", "status": "ok" if os.path.exists("/usr/bin/pnpm") or os.path.exists("/usr/local/bin/pnpm") else "fail", "detail": "pnpm"},
  {"name": "app service", "status": "${app_service_status}", "detail": "${APP_SYSTEMD_SERVICE}"},
  {"name": "app health", "status": "${app_health_status}", "detail": "${APP_PUBLIC_URL}/healthz"},
  {"name": "setup api", "status": "${setup_api_status}", "detail": "${APP_PUBLIC_URL}/_emdash/api/setup/status"},
  {"name": "backup schedule", "status": "ok" if os.path.exists("/etc/cron.d/emdash-backup") else "fail", "detail": "/etc/cron.d/emdash-backup"},
]
print(json.dumps({"checks": checks, "healthy": as_bool("HEALTHY")}, ensure_ascii=False, indent=2))
PY
		return
	fi

	status_command 0
}

