http_ok() {
	local url="$1"
	curl -fsS --max-time 5 "${url}" >/dev/null 2>&1
}

wait_for_http_ok() {
	local url="$1"
	local timeout_seconds="${2:-120}"
	local start now
	start="$(date +%s)"
	while true; do
		if http_ok "${url}"; then
			return 0
		fi
		now="$(date +%s)"
		if (( now - start >= timeout_seconds )); then
			return 1
		fi
		sleep 5
	done
}

