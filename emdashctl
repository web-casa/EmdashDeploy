log() { printf '[INFO] %s\n' "$*"; }
warn() { printf '[WARN] %s\n' "$*" >&2; }
fail() { printf '[ERROR] %s\n' "$*" >&2; exit 1; }

usage() {
	cat <<EOF
emdashctl

$(ct usage_title)
  emdashctl [--lang <code>] status [--json]
  emdashctl [--lang <code>] doctor [--json]
  emdashctl [--lang <code>] smoke [--json]
  emdashctl [--lang <code>] logs [app|postgres|redis|caddy] [-f]
  emdashctl [--lang <code>] restart [app|postgres|redis|all|caddy]
  emdashctl [--lang <code>] backup
  emdashctl [--lang <code>] restore <backup-file>
  emdashctl [--lang <code>] upgrade app
  emdashctl [--lang <code>] upgrade caddy-config
  emdashctl [--lang <code>] reset-db-password
EOF
}

parse_lang_args() {
	local remaining=()
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--lang=*)
			EMDASH_INSTALL_LANG="$(normalize_ctl_lang "${1#--lang=}")"
			;;
		--lang)
			shift
			[[ $# -gt 0 ]] || fail "Missing value for --lang"
			EMDASH_INSTALL_LANG="$(normalize_ctl_lang "$1")"
			;;
		*)
			remaining+=("$1")
			;;
		esac
		shift || true
	done
	printf '%s\n' "${remaining[@]}"
}

load_env() {
	[[ -f "${ENV_FILE}" ]] || fail "$(ct missing_env): ${ENV_FILE}"
	set -a
	# shellcheck disable=SC1090
	source "${ENV_FILE}"
	set +a
	ROOT_DIR="${ROOT_DIR:-/data/emdash}"
	APP_ENV_FILE="${APP_ENV_FILE:-${ENV_FILE}}"
	INSTALL_YAML="${INSTALL_YAML:-/etc/emdash/install.yml}"
	SITE_DIR="${SITE_DIR:-${ROOT_DIR}/app/site}"
	SCRIPTS_DIR="${SCRIPTS_DIR:-${ROOT_DIR}/scripts}"
	TMP_DIR="${TMP_DIR:-${ROOT_DIR}/tmp}"
	BACKUP_DIR="${BACKUP_DIR:-${ROOT_DIR}/backups}"
	UPLOADS_DIR="${UPLOADS_DIR:-${ROOT_DIR}/data/uploads}"
	SESSIONS_DIR="${SESSIONS_DIR:-${ROOT_DIR}/data/sessions}"
	SQLITE_DIR="${SQLITE_DIR:-${ROOT_DIR}/data/sqlite}"
	SQLITE_PATH="${SQLITE_PATH:-${SQLITE_DIR}/data.db}"
	APP_SYSTEMD_SERVICE="${APP_SYSTEMD_SERVICE:-emdash-app}"
	APP_SYSTEMD_UNIT="${APP_SYSTEMD_UNIT:-/etc/systemd/system/${APP_SYSTEMD_SERVICE}.service}"
	APP_BUILD_SCRIPT="${APP_BUILD_SCRIPT:-${SCRIPTS_DIR}/emdash-build.sh}"
	APP_START_SCRIPT="${APP_START_SCRIPT:-${SCRIPTS_DIR}/emdash-start.sh}"
}

bool_active() {
	systemctl is-active --quiet "$1"
}

service_name_for() {
	case "${1:-app}" in
	app) printf '%s\n' "${APP_SYSTEMD_SERVICE}" ;;
	postgres) printf '%s\n' "${POSTGRES_SERVICE}" ;;
	redis) printf '%s\n' "${REDIS_SERVICE}" ;;
	caddy) printf 'caddy\n' ;;
	*) return 1 ;;
	esac
}

local_health_url() {
	printf 'http://127.0.0.1:%s/healthz\n' "${APP_PORT}"
}

local_setup_url() {
	printf 'http://127.0.0.1:%s/_emdash/api/setup/status\n' "${APP_PORT}"
}

wait_http_ok() {
	local url="$1" tries="${2:-60}" i
	for ((i=1; i<=tries; i++)); do
		if curl -fsS --max-time 5 "${url}" >/dev/null 2>&1; then
			return 0
		fi
		sleep 2
	done
	return 1
}

update_env_value() {
	local key="$1"
	local value="$2"
	local file="${3:-${APP_ENV_FILE}}"
	KEY="${key}" VALUE="${value}" TARGET_FILE="${file}" python3 <<'PY'
from pathlib import Path
import os

def quote(value: str) -> str:
    value = value.replace("\\", "\\\\").replace('"', '\\"').replace("$", "\\$").replace("`", "\\`").replace("\n", "\\n")
    return f'"{value}"'

path = Path(os.environ["TARGET_FILE"])
key = os.environ["KEY"]
value = os.environ["VALUE"]
lines = []
updated = False
if path.exists():
    for raw in path.read_text().splitlines():
        if raw.startswith(f"{key}="):
            lines.append(f"{key}={quote(value)}")
            updated = True
        else:
            lines.append(raw)
if not updated:
    lines.append(f"{key}={quote(value)}")
path.write_text("\n".join(lines) + "\n")
PY
}

create_site_rollback() {
	local rollback_dir
	mkdir -p "${TMP_DIR}"
	rollback_dir="$(mktemp -d "${TMP_DIR}/emdashctl-site-rollback.XXXXXX")"
	if [[ -d "${SITE_DIR}" ]]; then
		mkdir -p "${rollback_dir}/site"
		cp -a "${SITE_DIR}/." "${rollback_dir}/site/"
	fi
	if [[ -d "${SCRIPTS_DIR}" ]]; then
		mkdir -p "${rollback_dir}/scripts"
		cp -a "${SCRIPTS_DIR}/." "${rollback_dir}/scripts/"
	fi
	if [[ -f "${APP_ENV_FILE}" ]]; then
		mkdir -p "${rollback_dir}/app-env"
		cp -a "${APP_ENV_FILE}" "${rollback_dir}/app-env/content"
	else
		mkdir -p "${rollback_dir}/app-env"
		: >"${rollback_dir}/app-env/missing"
	fi
	if [[ -f "${APP_SYSTEMD_UNIT}" ]]; then
		mkdir -p "${rollback_dir}/systemd-unit"
		cp -a "${APP_SYSTEMD_UNIT}" "${rollback_dir}/systemd-unit/content"
	else
		mkdir -p "${rollback_dir}/systemd-unit"
		: >"${rollback_dir}/systemd-unit/missing"
	fi
	printf '%s\n' "${rollback_dir}"
}

restore_site_rollback() {
	local rollback_dir="$1"
	if [[ -d "${rollback_dir}/site" ]]; then
		rm -rf "${SITE_DIR}"
		mkdir -p "${SITE_DIR}"
		cp -a "${rollback_dir}/site/." "${SITE_DIR}/"
		chown -R "${APP_RUN_USER}:${APP_RUN_GROUP}" "${SITE_DIR}"
	fi
	if [[ -d "${rollback_dir}/scripts" ]]; then
		rm -rf "${SCRIPTS_DIR}"
		mkdir -p "${SCRIPTS_DIR}"
		cp -a "${rollback_dir}/scripts/." "${SCRIPTS_DIR}/"
		chown -R "${APP_RUN_USER}:${APP_RUN_GROUP}" "${SCRIPTS_DIR}"
	fi
	if [[ -f "${rollback_dir}/app-env/content" ]]; then
		mkdir -p "$(dirname "${APP_ENV_FILE}")"
		cp -a "${rollback_dir}/app-env/content" "${APP_ENV_FILE}"
	elif [[ -f "${rollback_dir}/app-env/missing" ]]; then
		rm -f "${APP_ENV_FILE}"
	fi
	if [[ -f "${rollback_dir}/systemd-unit/content" ]]; then
		mkdir -p "$(dirname "${APP_SYSTEMD_UNIT}")"
		cp -a "${rollback_dir}/systemd-unit/content" "${APP_SYSTEMD_UNIT}"
	elif [[ -f "${rollback_dir}/systemd-unit/missing" ]]; then
		rm -f "${APP_SYSTEMD_UNIT}"
	fi
	systemctl daemon-reload >/dev/null 2>&1 || true
}

migrate_managed_script_paths_if_legacy() {
	local old_build_script="${APP_BUILD_SCRIPT}"
	local old_start_script="${APP_START_SCRIPT}"
	local new_build_script="${APP_BUILD_SCRIPT}"
	local new_start_script="${APP_START_SCRIPT}"
	local migrated="0"

	if [[ "${APP_BUILD_SCRIPT}" != "${SITE_DIR}/"* && "${APP_START_SCRIPT}" != "${SITE_DIR}/"* ]]; then
		return 0
	fi

	mkdir -p "${SCRIPTS_DIR}"

	if [[ "${APP_BUILD_SCRIPT}" == "${SITE_DIR}/"* ]]; then
		new_build_script="${SCRIPTS_DIR}/$(basename "${APP_BUILD_SCRIPT}")"
		if [[ -f "${old_build_script}" && "${old_build_script}" != "${new_build_script}" ]]; then
			cp -a "${old_build_script}" "${new_build_script}"
		fi
		APP_BUILD_SCRIPT="${new_build_script}"
		update_env_value "SCRIPTS_DIR" "${SCRIPTS_DIR}" "${APP_ENV_FILE}"
		update_env_value "APP_BUILD_SCRIPT" "${APP_BUILD_SCRIPT}" "${APP_ENV_FILE}"
		migrated="1"
	fi

	if [[ "${APP_START_SCRIPT}" == "${SITE_DIR}/"* ]]; then
		new_start_script="${SCRIPTS_DIR}/$(basename "${APP_START_SCRIPT}")"
		if [[ -f "${old_start_script}" && "${old_start_script}" != "${new_start_script}" ]]; then
			cp -a "${old_start_script}" "${new_start_script}"
		fi
		APP_START_SCRIPT="${new_start_script}"
		update_env_value "SCRIPTS_DIR" "${SCRIPTS_DIR}" "${APP_ENV_FILE}"
		update_env_value "APP_START_SCRIPT" "${APP_START_SCRIPT}" "${APP_ENV_FILE}"
		migrated="1"
	fi

	if [[ "${migrated}" == "1" && "${old_start_script}" != "${APP_START_SCRIPT}" && -f "${APP_SYSTEMD_UNIT}" ]]; then
		OLD_START_SCRIPT="${old_start_script}" NEW_START_SCRIPT="${APP_START_SCRIPT}" TARGET_FILE="${APP_SYSTEMD_UNIT}" python3 <<'PY'
from pathlib import Path
import os

path = Path(os.environ["TARGET_FILE"])
old = os.environ["OLD_START_SCRIPT"]
new = os.environ["NEW_START_SCRIPT"]
text = path.read_text()
updated = text.replace(f"ExecStart=/usr/bin/bash {old}", f"ExecStart=/usr/bin/bash {new}")
if updated != text:
    path.write_text(updated)
PY
	fi

	if id "${APP_RUN_USER}" >/dev/null 2>&1; then
		chown -R "${APP_RUN_USER}:${APP_RUN_GROUP}" "${SCRIPTS_DIR}"
	fi
	if [[ "${migrated}" == "1" ]]; then
		systemctl daemon-reload >/dev/null 2>&1 || true
		log "迁移旧脚本路径到 ${SCRIPTS_DIR}"
	fi
}

postgres_alter_password() {
	local role="$1"
	local password="$2"
	local alter_sql
	alter_sql="$(python3 - "${role}" "${password}" <<'PY'
import sys

user = sys.argv[1].replace('"', '""')
password = sys.argv[2].replace("'", "''")
print(f'ALTER ROLE "{user}" WITH PASSWORD \'{password}\';')
PY
)"
	runuser -u postgres -- psql postgres -c "${alter_sql}" >/dev/null
}

ensure_template_source_checkout() {
	[[ -n "${TEMPLATE_SOURCE_DIR:-}" ]] || fail "TEMPLATE_SOURCE_DIR is not configured"
	[[ -n "${TEMPLATES_REPO:-}" ]] || fail "TEMPLATES_REPO is not configured"
	[[ -n "${TEMPLATES_REF:-}" ]] || fail "TEMPLATES_REF is not configured"
	if [[ -d "${TEMPLATE_SOURCE_DIR}/.git" ]]; then
		git -C "${TEMPLATE_SOURCE_DIR}" pull --ff-only
		return
	fi
	rm -rf "${TEMPLATE_SOURCE_DIR}"
	git clone --depth 1 --branch "${TEMPLATES_REF}" "${TEMPLATES_REPO}" "${TEMPLATE_SOURCE_DIR}"
}

sync_template_site_tree() {
	[[ -n "${TEMPLATE:-}" ]] || fail "TEMPLATE is not configured"
	local template_path="${TEMPLATE_SOURCE_DIR}/${TEMPLATE}"
	[[ -d "${template_path}" ]] || fail "Template directory not found: ${template_path}"
	rm -rf "${SITE_DIR}"
	mkdir -p "${SITE_DIR}"
	cp -a "${template_path}/." "${SITE_DIR}/"
}

patch_site_package_json() {
	PROJECT_NAME="${PROJECT_NAME:-emdash}" \
	SITE_DIR="${SITE_DIR}" \
	DB_DRIVER="${DB_DRIVER}" \
	SESSION_DRIVER="${SESSION_DRIVER}" \
	STORAGE_DRIVER="${STORAGE_DRIVER}" \
	python3 <<'PY'
import json
import os
from pathlib import Path

pkg_path = Path(os.environ["SITE_DIR"]) / "package.json"
pkg = json.loads(pkg_path.read_text())
pkg["name"] = os.environ.get("PROJECT_NAME", "emdash")
pkg["packageManager"] = "pnpm@10.28.0"
pkg.setdefault("emdash", {})
if (pkg_path.parent / "seed" / "seed.json").exists():
    pkg["emdash"]["seed"] = "seed/seed.json"

deps = pkg.setdefault("dependencies", {})
deps["kysely"] = "^0.27.6"
if os.environ["DB_DRIVER"] == "postgres":
    deps["pg"] = "^8.16.3"
if os.environ["SESSION_DRIVER"] == "redis":
    deps["ioredis"] = "^5.7.0"
if os.environ["STORAGE_DRIVER"] == "s3":
    deps["@aws-sdk/client-s3"] = "^3.879.0"
    deps["@aws-sdk/s3-request-presigner"] = "^3.879.0"

pkg_path.write_text(json.dumps(pkg, indent=2) + "\n")
PY
}

render_site_astro_config() {
	SITE_DIR="${SITE_DIR}" DB_DRIVER="${DB_DRIVER}" SESSION_DRIVER="${SESSION_DRIVER}" STORAGE_DRIVER="${STORAGE_DRIVER}" python3 <<'PY'
import os
import re
from pathlib import Path

site_dir = Path(os.environ["SITE_DIR"])
path = site_dir / "astro.config.mjs"
text = path.read_text()

db_driver = os.environ["DB_DRIVER"]
session_driver = os.environ["SESSION_DRIVER"]
storage_driver = os.environ["STORAGE_DRIVER"]


def update_named_import(source: str, module: str, required: list[str]) -> str:
    pattern = rf'import\s*\{{\s*([^}}]*)\s*\}}\s*from\s*"{re.escape(module)}";'
    match = re.search(pattern, source)
    if not match:
        raise SystemExit(f"missing import for {module} in {path}")
    names = [item.strip() for item in match.group(1).split(",") if item.strip()]
    merged: list[str] = []
    for name in names + required:
        if name not in merged:
            merged.append(name)
    if module == "astro/config" and session_driver != "redis":
        merged = [name for name in merged if name != "sessionDrivers"]
    replacement = f'import {{ {", ".join(merged)} }} from "{module}";'
    return source[:match.start()] + replacement + source[match.end():]


def update_emdash_import(source: str) -> str:
    pattern = r'import\s+emdash,\s*\{\s*([^}]*)\s*\}\s*from\s*"emdash/astro";'
    match = re.search(pattern, source)
    if not match:
        raise SystemExit(f'missing emdash/astro import in {path}')
    names = [item.strip() for item in match.group(1).split(",") if item.strip()]
    required = ["local"]
    if storage_driver == "s3":
        required.append("s3")
    merged: list[str] = []
    for name in names + required:
        if name not in merged:
            merged.append(name)
    replacement = f'import emdash, {{ {", ".join(merged)} }} from "emdash/astro";'
    return source[:match.start()] + replacement + source[match.end():]


def update_db_import(source: str) -> str:
    required = "postgres" if db_driver == "postgres" else "sqlite"
    pattern = r'import\s*\{\s*([^}]*)\s*\}\s*from\s*"emdash/db";'
    match = re.search(pattern, source)
    if not match:
        raise SystemExit(f'missing emdash/db import in {path}')
    replacement = f'import {{ {required} }} from "emdash/db";'
    return source[:match.start()] + replacement + source[match.end():]


def replace_session_block(source: str) -> str:
    source = re.sub(
        r'\n\tsession:\s*\{\n\t\tdriver: sessionDrivers\.redis\(\{\n\t\t\turl: process\.env\.REDIS_URL,\n\t\t\}\),\n\t\},\n',
        '\n',
        source,
        count=1,
    )
    if session_driver != "redis":
        return source
    adapter_block = '\tadapter: node({\n\t\tmode: "standalone",\n\t}),\n'
    session_block = (
        '\tsession: {\n'
        '\t\tdriver: sessionDrivers.redis({\n'
        '\t\t\turl: process.env.REDIS_URL,\n'
        '\t\t}),\n'
        '\t},\n'
    )
    if adapter_block not in source:
        raise SystemExit(f'cannot find adapter block in {path}')
    return source.replace(adapter_block, adapter_block + session_block, 1)


def replace_emdash_block(source: str) -> str:
    pattern = r'emdash\(\{\n(?P<body>[\s\S]*?)\n\t\t\}\)'
    match = re.search(pattern, source)
    if not match:
        raise SystemExit(f'cannot find emdash config block in {path}')
    body = match.group("body")
    body = re.sub(r'^\t\t\tsiteUrl:.*\n', '', body, flags=re.MULTILINE)
    body = re.sub(
        r'^\t\t\tdatabase:\s*(?:sqlite|postgres)\(\{[\s\S]*?\n\t\t\t\}\),\n?',
        '',
        body,
        flags=re.MULTILINE,
    )
    body = re.sub(
        r'^\t\t\tstorage:\s*(?:local|s3)\(\{[\s\S]*?\n\t\t\t\}\),\n?',
        '',
        body,
        flags=re.MULTILINE,
    )
    body = body.lstrip("\n")

    if db_driver == "postgres":
        db_block = (
            '\t\t\tdatabase: postgres({\n'
            '\t\t\t\thost: process.env.POSTGRES_HOST,\n'
            '\t\t\t\tport: Number(process.env.POSTGRES_PORT || "5432"),\n'
            '\t\t\t\tdatabase: process.env.PG_DB_NAME,\n'
            '\t\t\t\tuser: process.env.PG_DB_USER,\n'
            '\t\t\t\tpassword: process.env.PG_DB_PASSWORD,\n'
            '\t\t\t}),\n'
        )
    else:
        db_block = (
            '\t\t\tdatabase: sqlite({\n'
            '\t\t\t\turl: `file:${process.env.SQLITE_PATH}`,\n'
            '\t\t\t}),\n'
        )

    if storage_driver == "s3":
        storage_block = (
            '\t\t\tstorage: s3({\n'
            '\t\t\t\tendpoint: process.env.S3_ENDPOINT,\n'
            '\t\t\t\tregion: process.env.S3_REGION,\n'
            '\t\t\t\tbucket: process.env.S3_BUCKET,\n'
            '\t\t\t\taccessKeyId: process.env.S3_ACCESS_KEY_ID,\n'
            '\t\t\t\tsecretAccessKey: process.env.S3_SECRET_ACCESS_KEY,\n'
            '\t\t\t\tpublicUrl: process.env.S3_PUBLIC_URL || undefined,\n'
            '\t\t\t}),\n'
        )
    else:
        storage_block = (
            '\t\t\tstorage: local({\n'
            '\t\t\t\tdirectory: process.env.UPLOADS_DIR,\n'
            '\t\t\t\tbaseUrl: "/_emdash/api/media/file",\n'
            '\t\t\t}),\n'
        )

    site_url_line = '\t\t\tsiteUrl: process.env.EMDASH_SITE_URL || process.env.SITE_URL || undefined,\n'
    new_body = site_url_line + db_block + storage_block + body
    replacement = f'emdash({{\n{new_body}\n\t\t}})'
    return source[:match.start()] + replacement + source[match.end():]


text = update_named_import(text, "astro/config", ["defineConfig"] + (["sessionDrivers"] if session_driver == "redis" else []))
text = update_emdash_import(text)
text = update_db_import(text)
text = replace_session_block(text)
text = replace_emdash_block(text)

path.write_text(text)
PY
}

