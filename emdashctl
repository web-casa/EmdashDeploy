tls_cert_detail() {
	local host port tmp cert_block cert_info
	host="$(app_url_host)"
	port="$(app_url_port)"
	[[ -n "${host}" && -n "${port}" ]] || return 1
	tmp="$(mktemp)"
	if ! timeout 15 openssl s_client -servername "${host}" -connect "${host}:${port}" </dev/null >"${tmp}" 2>/dev/null; then
		rm -f "${tmp}"
		return 1
	fi
	cert_block="$(awk '/BEGIN CERTIFICATE/,/END CERTIFICATE/ { print }' "${tmp}")"
	rm -f "${tmp}"
	[[ -n "${cert_block}" ]] || return 1
	cert_info="$(printf '%s\n' "${cert_block}" | openssl x509 -noout -subject -issuer -enddate 2>/dev/null | paste -sd '; ' -)"
	[[ -n "${cert_info}" ]] || return 1
	printf '%s\n' "${cert_info}"
}

