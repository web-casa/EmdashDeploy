logs_command() {
	local target="${1:-app}"
	local follow="${2:-0}"
	local service
	service="$(service_name_for "${target}")" || fail "Unknown logs target: ${target}"
	if [[ "${follow}" == "1" ]]; then
		exec journalctl -u "${service}" -f
	fi
	exec journalctl -u "${service}" -n 200 --no-pager
}

restart_command() {
	local target="${1:-app}"
	if [[ "${target}" == "all" ]]; then
		systemctl restart "${APP_SYSTEMD_SERVICE}"
		[[ "${SESSION_DRIVER}" == "redis" ]] && systemctl restart "${REDIS_SERVICE}"
		[[ "${DB_DRIVER}" == "postgres" ]] && systemctl restart "${POSTGRES_SERVICE}"
		[[ "${USE_CADDY}" == "1" ]] && systemctl restart caddy
		return
	fi
	systemctl restart "$(service_name_for "${target}")"
}

prune_local_backups() {
	local keep="${BACKUP_KEEP_LOCAL:-7}"
	mapfile -t backups < <(ls -1t "${BACKUP_DIR}"/emdash-backup-*.tar.gz 2>/dev/null || true)
	if (( ${#backups[@]} <= keep )); then
		return
	fi
	for old in "${backups[@]:keep}"; do
		rm -f "${old}"
	done
}

backup_command() {
	local ts archive tmpdir
	ts="$(date +%Y%m%d-%H%M%S)"
	archive="${BACKUP_DIR}/emdash-backup-${ts}.tar.gz"
	tmpdir="$(mktemp -d)"
	mkdir -p "${tmpdir}/meta" "${tmpdir}/data"
	cp -a "${INSTALL_YAML}" "${APP_ENV_FILE}" "${tmpdir}/meta/" 2>/dev/null || true

	if [[ "${DB_DRIVER}" == "sqlite" ]]; then
		mkdir -p "${tmpdir}/data/sqlite"
		python3 - "${SQLITE_PATH}" "${tmpdir}/data/sqlite/data.db" <<'PY'
import sqlite3, sys
src, dst = sys.argv[1], sys.argv[2]
src_db = sqlite3.connect(src)
dst_db = sqlite3.connect(dst)
src_db.backup(dst_db)
dst_db.close()
src_db.close()
PY
	else
		PGPASSWORD="${PG_DB_PASSWORD}" pg_dump -h "${POSTGRES_HOST}" -p "${POSTGRES_PORT}" -U "${PG_DB_USER}" -d "${PG_DB_NAME}" >"${tmpdir}/data/postgres.sql"
	fi

	if [[ "${STORAGE_DRIVER}" == "local" && -d "${UPLOADS_DIR}" ]]; then
		cp -a "${UPLOADS_DIR}" "${tmpdir}/data/uploads"
	fi
	if [[ "${SESSION_DRIVER}" == "file" && -d "${SESSIONS_DIR}" ]]; then
		cp -a "${SESSIONS_DIR}" "${tmpdir}/data/sessions"
	fi

	tar -C "${tmpdir}" -czf "${archive}" .
	rm -rf "${tmpdir}"

	if [[ "${BACKUP_TARGET_TYPE}" == "s3" ]]; then
		python3 - "${BACKUP_S3_ENDPOINT}" "${BACKUP_S3_REGION}" "${BACKUP_S3_BUCKET}" "${BACKUP_S3_ACCESS_KEY_ID}" "${BACKUP_S3_SECRET_ACCESS_KEY}" "${BACKUP_S3_PREFIX%/}/$(basename "${archive}")" "${archive}" <<'PY'
import sys
import boto3
from botocore.config import Config

endpoint, region, bucket, access, secret, key, archive_path = sys.argv[1:]
client = boto3.client(
    "s3",
    endpoint_url=endpoint,
    aws_access_key_id=access,
    aws_secret_access_key=secret,
    region_name=region,
    config=Config(signature_version="s3v4"),
)
with open(archive_path, "rb") as fh:
    client.upload_fileobj(fh, bucket, key)
PY
	fi

	prune_local_backups
	log "$(ct backup_complete): ${archive}"
}

restore_command() {
	local archive="$1"
	local tmpdir ts tmp_db old_db
	[[ -f "${archive}" ]] || fail "Backup file not found: ${archive}"
	tmpdir="$(mktemp -d)"
	tar -C "${tmpdir}" -xzf "${archive}"
	if [[ "${DB_DRIVER}" == "postgres" ]]; then
		# PostgreSQL restore is executed as the postgres OS user, so the extracted
		# dump must be readable outside the root-only mktemp directory.
		chmod 0755 "${tmpdir}" "${tmpdir}/data" 2>/dev/null || true
		chmod 0644 "${tmpdir}/data/postgres.sql" 2>/dev/null || true
	fi
	systemctl stop "${APP_SYSTEMD_SERVICE}" || true

	if [[ "${DB_DRIVER}" == "sqlite" ]]; then
		[[ -f "${tmpdir}/data/sqlite/data.db" ]] || fail "SQLite backup file not found in archive"
		mkdir -p "${SQLITE_DIR}"
		rm -f "${SQLITE_PATH}" "${SQLITE_PATH}-wal" "${SQLITE_PATH}-shm"
		install -m 0640 -o "${APP_RUN_USER}" -g "${APP_RUN_GROUP}" "${tmpdir}/data/sqlite/data.db" "${SQLITE_PATH}"
	else
		[[ -f "${tmpdir}/data/postgres.sql" ]] || fail "PostgreSQL dump not found in archive"
		ts="$(date +%s)"
		tmp_db="${PG_DB_NAME}_restore_${ts}"
		old_db="${PG_DB_NAME}_pre_restore_${ts}"
		runuser -u postgres -- createdb -O "${PG_DB_USER}" "${tmp_db}"
		runuser -u postgres -- psql -d "${tmp_db}" -f "${tmpdir}/data/postgres.sql" >/dev/null
		runuser -u postgres -- psql postgres <<EOF
SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname IN ('${PG_DB_NAME}', '${tmp_db}');
ALTER DATABASE ${PG_DB_NAME} RENAME TO ${old_db};
ALTER DATABASE ${tmp_db} RENAME TO ${PG_DB_NAME};
EOF
	fi

	if [[ -d "${tmpdir}/data/uploads" ]]; then
		mkdir -p "${UPLOADS_DIR}"
		rm -rf "${UPLOADS_DIR:?}/"*
		cp -a "${tmpdir}/data/uploads/." "${UPLOADS_DIR}/"
		chown -R "${APP_RUN_USER}:${APP_RUN_GROUP}" "${UPLOADS_DIR}"
	fi
	if [[ -d "${tmpdir}/data/sessions" ]]; then
		mkdir -p "${SESSIONS_DIR}"
		rm -rf "${SESSIONS_DIR:?}/"*
		cp -a "${tmpdir}/data/sessions/." "${SESSIONS_DIR}/"
		chown -R "${APP_RUN_USER}:${APP_RUN_GROUP}" "${SESSIONS_DIR}"
	fi
	rm -rf "${tmpdir}"

	systemctl start "${APP_SYSTEMD_SERVICE}"
	wait_http_ok "$(local_health_url)" 60 || fail "Application did not become healthy after restore"
	log "$(ct restore_complete)"
}

upgrade_command() {
	local target="$1"
	local rollback_dir
	case "${target}" in
	app)
		migrate_managed_script_paths_if_legacy
		rollback_dir="$(create_site_rollback)"
		systemctl stop "${APP_SYSTEMD_SERVICE}" || true
		if ! {
			ensure_template_source_checkout &&
			sync_template_site_tree &&
			refresh_managed_site_files &&
			runuser -u "${APP_RUN_USER}" -- bash -lc "${APP_BUILD_SCRIPT}"
		}; then
			warn "Upgrade failed; restoring previous site tree."
			restore_site_rollback "${rollback_dir}"
			rm -rf "${rollback_dir}"
			systemctl start "${APP_SYSTEMD_SERVICE}" || true
			fail "Application upgrade failed; previous site tree was restored."
		fi
		systemctl start "${APP_SYSTEMD_SERVICE}"
		if ! wait_http_ok "$(local_health_url)" 60; then
			warn "Upgraded app did not become healthy; rolling back site tree."
			systemctl stop "${APP_SYSTEMD_SERVICE}" || true
			restore_site_rollback "${rollback_dir}"
			rm -rf "${rollback_dir}"
			systemctl start "${APP_SYSTEMD_SERVICE}" || true
			fail "Application did not become healthy after upgrade; previous site tree was restored."
		fi
		rm -rf "${rollback_dir}"
		;;
	caddy-config)
		[[ "${USE_CADDY}" == "1" ]] || fail "caddy is not enabled"
		caddy validate --config /etc/caddy/Caddyfile
		systemctl reload caddy
		;;
	*)
		fail "$(ct upgrade_supported)"
		;;
	esac
}

reset_db_password_command() {
	[[ "${DB_DRIVER}" == "postgres" ]] || fail "$(ct reset_only_postgres)"
	local new_password old_password pg_user_encoded pg_password_encoded pg_db_name_encoded rollback_dir env_backup db_password_changed="0"
	new_password="$(openssl rand -hex 16)"
	old_password="${PG_DB_PASSWORD}"
	migrate_managed_script_paths_if_legacy
	rollback_dir="$(create_site_rollback)"
	env_backup="${rollback_dir}/emdash.env"
	cp -a "${APP_ENV_FILE}" "${env_backup}"
	systemctl stop "${APP_SYSTEMD_SERVICE}" || true
	if ! {
		postgres_alter_password "${PG_DB_USER}" "${new_password}" &&
		db_password_changed="1" &&
		update_env_value "PG_DB_PASSWORD" "${new_password}" "${APP_ENV_FILE}"
	}; then
		if [[ "${db_password_changed}" == "1" ]]; then
			postgres_alter_password "${PG_DB_USER}" "${old_password}" || true
		fi
		cp -a "${env_backup}" "${APP_ENV_FILE}" 2>/dev/null || true
		restore_site_rollback "${rollback_dir}"
		rm -rf "${rollback_dir}"
		systemctl start "${APP_SYSTEMD_SERVICE}" || true
		fail "Failed to update PostgreSQL password."
	fi
	pg_user_encoded="$(python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "${PG_DB_USER}")"
	pg_password_encoded="$(python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "${new_password}")"
	pg_db_name_encoded="$(python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "${PG_DB_NAME}")"
	if ! {
		update_env_value "DATABASE_URL" "postgres://${pg_user_encoded}:${pg_password_encoded}@${POSTGRES_HOST}:${POSTGRES_PORT}/${pg_db_name_encoded}" "${APP_ENV_FILE}" &&
		render_site_astro_config &&
		chown "${APP_RUN_USER}:${APP_RUN_GROUP}" "${SITE_DIR}/astro.config.mjs" &&
		runuser -u "${APP_RUN_USER}" -- bash -lc "${APP_BUILD_SCRIPT}"
	}; then
		warn "Password reset rebuild failed; rolling back PostgreSQL password and app files."
		if [[ "${db_password_changed}" == "1" ]]; then
			postgres_alter_password "${PG_DB_USER}" "${old_password}" || true
		fi
		cp -a "${env_backup}" "${APP_ENV_FILE}" 2>/dev/null || true
		restore_site_rollback "${rollback_dir}"
		rm -rf "${rollback_dir}"
		systemctl start "${APP_SYSTEMD_SERVICE}" || true
		fail "Password reset failed; previous password and app files were restored."
	fi
	systemctl start "${APP_SYSTEMD_SERVICE}"
	if ! wait_http_ok "$(local_health_url)" 60; then
		warn "Application did not become healthy after password reset; rolling back."
		systemctl stop "${APP_SYSTEMD_SERVICE}" || true
		if [[ "${db_password_changed}" == "1" ]]; then
			postgres_alter_password "${PG_DB_USER}" "${old_password}" || true
		fi
		cp -a "${env_backup}" "${APP_ENV_FILE}" 2>/dev/null || true
		restore_site_rollback "${rollback_dir}"
		rm -rf "${rollback_dir}"
		systemctl start "${APP_SYSTEMD_SERVICE}" || true
		fail "Application did not become healthy after password reset; previous password and app files were restored."
	fi
	rm -rf "${rollback_dir}"
	printf '%s\n' "${new_password}"
}

main() {
	local args command json_flag="0" follow="0"
	mapfile -t args < <(parse_lang_args "$@")
	set -- "${args[@]}"
	[[ $# -gt 0 ]] || { usage; exit 0; }
	command="$1"
	shift || true
	[[ "${command}" == "-h" || "${command}" == "--help" ]] && { usage; exit 0; }
	load_env

	case "${command}" in
	status)
		[[ "${1:-}" == "--json" ]] && json_flag="1"
		status_command "${json_flag}"
		;;
	doctor)
		[[ "${1:-}" == "--json" ]] && json_flag="1"
		doctor_command "${json_flag}"
		;;
	smoke)
		[[ "${1:-}" == "--json" ]] && json_flag="1"
		smoke_command "${json_flag}"
		;;
	logs)
		[[ "${2:-}" == "-f" || "${1:-}" == "-f" ]] && follow="1"
		logs_command "${1:-app}" "${follow}"
		;;
	restart)
		restart_command "${1:-app}"
		;;
	backup)
		backup_command
		;;
	restore)
		[[ $# -ge 1 ]] || fail "restore requires a backup file"
		restore_command "$1"
		;;
	upgrade)
		[[ $# -ge 1 ]] || fail "$(ct upgrade_supported)"
		upgrade_command "$1"
		;;
	reset-db-password)
		reset_db_password_command
		;;
	*)
		fail "$(ct unknown_command): ${command}"
		;;
	esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
	main "$@"
fi
