	local lang="${EMDASH_INSTALL_LANG:-en}"
	case "${key}" in
	usage_title) case "${lang}" in en) printf 'Usage:' ;; ja) printf '使い方:' ;; ko) printf '사용법:' ;; es) printf 'Uso:' ;; de) printf 'Verwendung:' ;; fr) printf 'Utilisation :' ;; zh-CN) printf '用法:' ;; zh-TW) printf '用法:' ;; pt) printf 'Uso:' ;; esac ;;
	missing_env) case "${lang}" in en) printf 'Missing environment file' ;; ja) printf '環境ファイルが見つかりません' ;; ko) printf '환경 파일이 없습니다' ;; es) printf 'Falta el archivo de entorno' ;; de) printf 'Umgebungsdatei fehlt' ;; fr) printf 'Fichier d’environnement manquant' ;; zh-CN) printf '缺少环境文件' ;; zh-TW) printf '缺少環境檔' ;; pt) printf 'Arquivo de ambiente ausente' ;; esac ;;
